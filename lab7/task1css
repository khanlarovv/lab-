body {
    background-color: #f5f5f5;
    font-family: Arial, sans-serif;
    padding: 40px;
}
.container {
    background-color: #fff;
    padding: 20px;
    max-width: 400px;
    border: 1px solid #ddd;
    border-radius: 5px;
}
input {
    padding: 8px;
    width: 60%;
    margin-right: 5px;
}
button {
    padding: 8px 15px;
    background-color: #0056b3;
    color: white;
    border: none;
    cursor: pointer;
}
#neticeP {
    margin-top: 15px;
    color: #333;
}
