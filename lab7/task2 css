body {
    background-color: #f5f5f5;
    font-family: Arial, sans-serif;
    padding: 40px;
}
.kalkulyator {
    background-color: #fff;
    padding: 20px;
    max-width: 300px;
    border: 1px solid #ddd;
    border-radius: 5px;
}
input {
    width: 100%;
    padding: 8px;
    margin-bottom: 10px;
}
.duymeler {
    display: flex;
    gap: 10px;
}
button {
    flex: 1;
    padding: 10px;
    font-size: 18px;
    cursor: pointer;
}
#kalkNetice {
    margin-top: 15px;
    font-weight: bold;
}
